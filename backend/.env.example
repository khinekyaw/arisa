PORT=3001

# ── Provider toggles ──────────────────────────────────────────────
# Voice providers default to xAI. Set to "elevenlabs" to fall back.
TTS_PROVIDER=xai
STT_PROVIDER=xai

# ── xAI (LLM + default TTS/STT) ───────────────────────────────────
XAI_API_KEY=xai-...
XAI_TTS_VOICE=Eve

# ── ElevenLabs (fallback TTS/STT) ─────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime

# ── Misc ──────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
DATABASE_PATH=./arisa.db

# ── Deployment ────────────────────────────────────────────────────
# Reverse proxies in front of the app (for correct client IP / rate limiting).
# 1 = behind one proxy (nginx / PaaS); 0 = exposed directly.
TRUST_PROXY=1
# Built frontend to serve (single-host deploy). Defaults to ../web/dist.
# STATIC_DIR=/app/web/dist

# ── Rate limiting (per IP, on /api/chat) ──────────────────────────
RATE_LIMIT_PER_MIN=10
RATE_LIMIT_PER_DAY=100
