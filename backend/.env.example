PORT=3001

# ── Provider toggles ──────────────────────────────────────────────
# Voice providers default to xAI. Set to "elevenlabs" to fall back.
TTS_PROVIDER=xai
STT_PROVIDER=xai

# ── xAI (LLM + default TTS/STT) ───────────────────────────────────
XAI_API_KEY=xai-...
XAI_TTS_VOICE=Eve

# ── ElevenLabs (fallback TTS/STT) ─────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime

# ── Misc ──────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
DATABASE_PATH=./arisa.db
