# Loaded by every Vite command.
VITE_DEBUG=false

# Dev only — put these in .env.development. They point the app at the separate
# backend dev port. For single-host PRODUCTION builds, leave them UNSET so the
# app talks to the same origin it is served from (relative /api/ and same-host
# wss). Do not set them to empty strings — unset them entirely.
# VITE_API_URL=http://localhost:3001/api/
# VITE_WS_URL=ws://localhost:3001/api/transcribe
